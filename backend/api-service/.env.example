# Backend environment configuration
# Copy this file to .env and fill in your values
# .env is gitignored — never commit real secrets

# ── Required for real AI detection ──────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here

# ── Optional: change JWT secret in production ────────────────────────────────
# JWT_SECRET=change-this-to-a-long-random-string

# ── Database (default: SQLite) ───────────────────────────────────────────────
# DATABASE_URL=postgresql://user:password@localhost:5432/laundry

# ── AWS S3 (only needed for production S3 storage) ───────────────────────────
# AWS_S3_BUCKET=your-bucket-name
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=xxx
# AWS_SECRET_ACCESS_KEY=xxx
# AWS_CLOUDFRONT_URL=https://dXXXXXX.cloudfront.net
